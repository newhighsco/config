{
  "name": "@newhighsco/commitlint-config",
  "description": "New High Score shareable config for commitlint",
  "version": "1.3.1",
  "author": "New High Score",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/newhighsco/config.git",
    "directory": "packages/commitlint-config"
  },
  "homepage": "https://github.com/newhighsco/config/tree/main/packages/commitlint-config#readme",
  "bugs": {
    "url": "https://github.com/newhighsco/config/issues"
  },
  "type": "module",
  "main": "commitlint.config.js",
  "files": [
    "scripts"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "test": "concurrently 'yarn:test:*'",
    "test:type": "echo 'fix: description' | commitlint --verbose --strict",
    "test:scope": "echo 'fix(scope): description' | commitlint --verbose --strict",
    "test:breaking:type": "echo 'fix!: description' | commitlint --verbose --strict",
    "test:breaking:scope": "echo 'fix(scope)!: description' | commitlint --verbose --strict",
    "test:breaking:footer": "echo 'fix(scope): description\n\nBREAKING CHANGE: footer' | commitlint --verbose --strict"
  },
  "dependencies": {
    "@commitlint/config-conventional": "21.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.1.0",
    "concurrently": "10.0.3"
  },
  "peerDependencies": {
    "@commitlint/cli": "21.1.0",
    "husky": "9.1.7"
  }
}
